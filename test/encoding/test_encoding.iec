DEFINE_CONFIGURATION(
	_JIEC_TESTNAMES_LIST_(
		'test_base64encode',
		'test_base64decode',
		'test_base64url_encode',
		'test_base64url_decode',
		'test_percentencode',
		'test_percentdecode',
		'test_hexencode',
		'test_hexdecode',
		'test_json_escape',
		'test_json_unescape',
		'test_bcd_encode',
		'test_bcd_decode'
	)
)
{#undef _TEST_}
{#endif}

