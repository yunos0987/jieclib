{#ifndef __TEST_CONTAINER_HASHSET_DINT_COLLISION_IEC__}
{#define __TEST_CONTAINER_HASHSET_DINT_COLLISION_IEC__}

{#include <sys.iec>}
{#include <sys_conv.iec>}

function Dint_collision_equals_for_hashset_test: bool
	_PROLOGUE_OF_FUNCTION_()
	var_input
		lhs: dint;
		rhs: dint;
	end
	{st}
	Dint_collision_equals_for_hashset_test := lhs = rhs;
	{end}
end

function Dint_collision_hash_for_hashset_test: udint
	_PROLOGUE_OF_FUNCTION_()
	var_input
		self: dint;
	end
	{st}
	Dint_collision_hash_for_hashset_test := udint#1;
	{end}
end

{#define HashSetName dint_collision}
{#define HashSetCapacity 8}
{#define HashSetElementType dint}
{#define HashSetElementEqualsFunction Dint_collision_equals_for_hashset_test}
{#define HashSetElementHashFunction Dint_collision_hash_for_hashset_test}
{#include <container/hashset/hashset_template.iec>}
{#undef HashSetName}
{#undef HashSetCapacity}
{#undef HashSetElementType}
{#undef HashSetElementEqualsFunction}
{#undef HashSetElementHashFunction}

{#endif}